import pandas as pd









df = pd.read_csv('marketing_campaign.csv')
# Subset the columns we are interested in
df = df[['ID','Year_Birth', 'Education','Marital_Status','Income','Kidhome', 'Teenhome', 'Dt_Customer','Recency','NumStorePurchases', 'NumWebVisitsMonth']]


df.head(5)


df.dtypes


df.shape





# Get average (mean) number of purchases based on number of kids at home
# We are grouping by "Kidhome" column, and aggregating by "NumStorePurchases" column
df.groupby('Kidhome')['NumStorePurchases'].mean()








